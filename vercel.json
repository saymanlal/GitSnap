{
    "name": "gitsnap-cloud",
    "version": 2,
    "routes": [
      {
        "src": "/",
        "dest": "/index.html"
      },
      {
        "src": "/auth.html",
        "dest": "/auth.html"
      },
      {
        "src": "/dashboard.html",
        "dest": "/dashboard.html"
      },
      {
        "src": "/(.*)",
        "dest": "/404.html"
      }
    ],
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          }
        ]
      },
      {
        "source": "/assets/(.*)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": "/404.html"
      }
    ],
    "github": {
      "silent": true,
      "autoDeploy": true,
      "autoJobCancel": true
    },
    "functions": {
      "api/*.js": {
        "maxDuration": 10
      }
    },
    "cleanUrls": true,
    "trailingSlash": false
  }